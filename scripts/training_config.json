{
  "model_type": "lstm",
  "learning_rate": 0.001,
  "batch_size": 256,
  "epochs": 50,
  "optimizer": "Adam",
  "weight_decay": 0.0001,
  "validation_split": 0.2,
  "early_stopping_patience": 10,
  "label_config": {
    "horizon": 5,
    "long_threshold": 0.005,
    "short_threshold": 0.005,
    "warmup_bars": 20
  },
  "lstm_config": {
    "hidden_size": 64,
    "num_layers": 2,
    "dropout": 0.2,
    "bidirectional": false
  }
}
